{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign",
  "version": "0.1.0",
  "identifier": "org.sovereign.engine",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:8002",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Sovereign // engine runtime",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["python3", "python3-pip"]
      }
    }
  }
}

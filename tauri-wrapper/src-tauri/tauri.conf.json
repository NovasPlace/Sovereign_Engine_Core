{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Node",
  "version": "1.0.0",
  "identifier": "com.sovereign.node",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sovereign Engine",
        "url": "http://127.0.0.1:8002",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
